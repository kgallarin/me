REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=
RESEND_API_KEY=
MAIL_FROM_NAME=
CONTACT_EMAIL=
MAIL_FROM_ADDRESS=

MEDIA_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
